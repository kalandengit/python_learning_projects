# Copy to .env and adjust. All variables are prefixed with STAFFHUB_.

# Core
STAFFHUB_ENVIRONMENT=development
STAFFHUB_DEBUG=true

# Database — SQLite for local/dev; PostgreSQL in production (RLS enforced there).
# STAFFHUB_DATABASE_URL=postgresql+psycopg://staffhub:staffhub@localhost:5432/staffhub
STAFFHUB_DATABASE_URL=sqlite:///./staffhub.db

# Auth — CHANGE the secret in every non-dev environment.
STAFFHUB_SECRET_KEY=change-me
STAFFHUB_ACCESS_TOKEN_TTL_MINUTES=60
STAFFHUB_INVITE_TOKEN_TTL_HOURS=72
STAFFHUB_RESET_TOKEN_TTL_HOURS=24

# ICS feed
STAFFHUB_ICS_TOKEN_TTL_DAYS=365

# Rate limits (per fixed window)
STAFFHUB_RATE_LIMIT_LOGIN=10
STAFFHUB_RATE_LIMIT_UPLOADS=20
STAFFHUB_RATE_LIMIT_REQUESTS=60
STAFFHUB_RATE_LIMIT_ICS=30
STAFFHUB_RATE_LIMIT_WINDOW_SECONDS=60
