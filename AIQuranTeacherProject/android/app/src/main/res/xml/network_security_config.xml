<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext HTTP is disabled by default (see AndroidManifest usesCleartextTraffic="false").
  This config permits cleartext ONLY for local development hosts (the Android
  emulator's 10.0.2.2 loopback and localhost), so production traffic must use HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
