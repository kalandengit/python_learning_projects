# Signaling server configuration. Copy to `.env` for local development.

PORT=3001

# MUST match the backend's JWT_SECRET so tokens issued by the API are accepted.
JWT_SECRET=CHANGE_ME_use_the_same_secret_as_the_backend

# Comma-separated allowed WebSocket/HTTP origins. Do NOT use "*" in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Max participants allowed in a single live-class room.
MAX_ROOM_SIZE=8

# Set to "true" to accept unauthenticated connections (development only).
ALLOW_ANONYMOUS=false
