# ---------------------------------------------------------------------------
# AI Quran Teacher — backend environment
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins. Use exact origins in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Database
# For local/dev/test the app defaults to an embedded SQLite file when DB_TYPE=sqlite.
# For production use DB_TYPE=postgres and provide connection details (or DATABASE_URL).
DB_TYPE=sqlite
DB_DATABASE=aiquran.sqlite
# DATABASE_URL=postgres://user:password@localhost:5432/aiquran
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=aiquran
# DB_PASSWORD=change-me
# DB_SSL=false
# Never enable synchronize in production — use migrations instead.
DB_SYNCHRONIZE=true

# Auth
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=3600s

# Mistral AI
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest
MISTRAL_TIMEOUT_MS=30000

# Rate limiting (requests per TTL window, per IP)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Stripe (payments / subscriptions)
# Use a RESTRICTED secret key with least privilege in production.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Publishable key is safe to expose to clients.
STRIPE_PUBLISHABLE_KEY=
# From the Stripe CLI (`stripe listen`) or the webhook endpoint settings.
STRIPE_WEBHOOK_SECRET=
# Price IDs for each plan (created in the Stripe dashboard, server-side allow-list).
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
# Redirect URLs after checkout / portal.
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/billing
