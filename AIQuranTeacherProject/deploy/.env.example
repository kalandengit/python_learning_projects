# ---------------------------------------------------------------------------
# AI Quran Teacher — deployment env for docker compose (copy to ../.env).
# Fill in secrets. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# --- Public address --------------------------------------------------------
# For a quick IP-only test leave SITE_ADDRESS as ":80" and set PUBLIC_URL to
# http://<your-vps-ip>. For HTTPS, set SITE_ADDRESS to your domain and
# ACME_EMAIL to a real address (Caddy will obtain a Let's Encrypt cert).
SITE_ADDRESS=:80
PUBLIC_URL=http://YOUR_VPS_IP
ACME_EMAIL=

# --- Database --------------------------------------------------------------
POSTGRES_USER=aiquran
POSTGRES_DB=aiquran
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_db_password

# --- Auth ------------------------------------------------------------------
# Generate: openssl rand -base64 48   (must be >= 32 chars)
JWT_SECRET=CHANGE_ME_long_random_secret_min_32_chars
JWT_ISSUER=ai-quran-teacher
JWT_AUDIENCE=ai-quran-teacher-clients

# --- Signaling -------------------------------------------------------------
# Keep false in any shared/public deployment (requires a valid JWT to connect).
SIGNALING_ALLOW_ANONYMOUS=false

# --- Mistral AI (optional; AI endpoints return 503 until set) --------------
MISTRAL_API_KEY=

# --- Stripe (optional; billing endpoints return 503 until set) -------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
