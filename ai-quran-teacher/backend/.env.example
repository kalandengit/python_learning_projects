# Copy to .env and adjust for your environment.

# --- Database (use DATABASE_URL in production, e.g. Heroku/RDS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ai_quran_teacher
# DATABASE_URL=postgres://user:pass@host:5432/ai_quran_teacher
# Set to "true" only in development; use migrations in production.
DB_SYNCHRONIZE=true
# Set "true" for managed Postgres that requires TLS (RDS, Heroku).
DB_SSL=false

PORT=3000

# --- Auth ---
# Generate a strong secret in production: `openssl rand -base64 48`
JWT_SECRET=dev-only-insecure-secret
JWT_EXPIRES_IN=7d

# --- Scaling / caching ---
# When set, enables Redis caching and horizontal scaling. Leave empty for single-node dev.
# REDIS_URL=redis://localhost:6379
RATE_LIMIT=100

# --- CORS ---
# Comma-separated allowed origins in production. Empty allows all (dev only).
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# --- AI Islamic tutor (Anthropic / Claude) ---
# See docs/LLM_GUIDE.md for model selection guidance.
# ANTHROPIC_API_KEY=sk-ant-...
# Max concurrent Claude requests across the process (parallel tutor fan-out).
LLM_MAX_CONCURRENCY=8
