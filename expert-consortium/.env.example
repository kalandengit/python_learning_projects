# Copy this file to .env and fill in your real values.  NEVER commit .env to git.
# Copiez ce fichier vers .env et remplissez vos vraies valeurs. Ne JAMAIS commiter .env.

# --- Required / Obligatoire ---
# Get your key at https://console.mistral.ai  (API Keys section)
MISTRAL_API_KEY=

# Password to open the web chat page (choose a long one)
# Mot de passe pour ouvrir la page de chat web (choisissez-le long)
WEB_PASSWORD=change-me-please

# --- Telegram (optional until Milestone 4 / optionnel) ---
# Token from @BotFather, and YOUR numeric Telegram user id (from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- Advanced (defaults are fine / les valeurs par défaut suffisent) ---
# Chat model: mistral-large-latest (best) or mistral-small-latest (cheaper),
# or your fine-tuned model id after Milestone 5 (ft:...)
CHAT_MODEL=mistral-large-latest
EMBED_MODEL=mistral-embed
OCR_MODEL=mistral-ocr-latest
TRANSCRIBE_MODEL=voxtral-mini-latest

# Leave QDRANT_URL empty to use embedded local storage in data/qdrant (no Docker needed).
# In Docker/VPS deployment this is set to http://qdrant:6333
QDRANT_URL=

# --- Scaling guards (optional, sensible defaults / optionnel) ---
# See docs/en/10-limits.md — Voir docs/fr/10-limits.md
#MAX_UPLOAD_MB=500
#MAX_OCR_MB=45
#AUDIO_SEGMENT_MINUTES=100
#CHAT_RATE_PER_MIN=30
