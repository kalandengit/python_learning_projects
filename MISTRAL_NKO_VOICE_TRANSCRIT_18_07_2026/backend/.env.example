# --- Required -------------------------------------------------------------
# >= 32 characters; the app refuses to start otherwise.
NKO_SECRET_KEY=change-me-to-a-random-string-of-at-least-32-chars

# --- Database -------------------------------------------------------------
# Production: postgresql+psycopg://nko:***@db:5432/nko  (SSL on, least-privilege role)
NKO_DATABASE_URL=sqlite:///./nko.db

# --- ASR ------------------------------------------------------------------
# Default engine for Manding languages: mock | mms
NKO_ASR_ENGINE=mock
NKO_MMS_MODEL_ID=facebook/mms-1b-all
# Pin to a specific commit hash for supply-chain safety (audit finding).
NKO_MMS_REVISION=main
# Air-gapped deployments: point at a local directory and forbid downloads.
#NKO_MMS_MODEL_DIR=/models/mms-1b-all
NKO_MMS_LOCAL_FILES_ONLY=false

# Mistral Voxtral (French + 12 other languages, batch transcription).
# Leave unset to disable the engine; the key never reaches clients.
#NKO_MISTRAL_API_KEY=
NKO_MISTRAL_API_BASE=https://api.mistral.ai
NKO_MISTRAL_TRANSCRIBE_MODEL=voxtral-mini-latest

# --- Limits & security ----------------------------------------------------
NKO_MAX_UPLOAD_BYTES=10485760
# JSON list of proxy IPs whose X-Forwarded-For is trusted (audit finding).
NKO_TRUSTED_PROXIES=[]
NKO_RATE_LIMIT_DEFAULT=120/minute
NKO_RATE_LIMIT_AUTH=10/minute
NKO_RATE_LIMIT_TRANSCRIBE=20/minute
# Token required for /api/health/detailed (audit finding). Unset = disabled.
#NKO_INTERNAL_HEALTH_TOKEN=

# --- Tokens ---------------------------------------------------------------
NKO_ACCESS_TOKEN_MINUTES=15
NKO_REFRESH_TOKEN_DAYS=7
