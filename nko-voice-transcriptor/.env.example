# N'KO Voice Transcriptor configuration
# Copy to .env and fill in. Never commit .env.

# REQUIRED. >=32 random chars. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
NKO_SECRET_KEY=

# sqlite (default, dev) or postgresql+psycopg://user:pass@host/db (prod)
NKO_DATABASE_URL=sqlite:///./nko.db

# ASR engine: "mock" (no ML deps, deterministic) or "mms" (requires torch+transformers)
NKO_ASR_ENGINE=mock
NKO_MMS_MODEL_ID=facebook/mms-1b-all

# Source languages offered (ISO 639-3, Manding varieties with MMS adapters)
NKO_LANGUAGES=bam,dyu,emk,mku,msc,mwk
NKO_DEFAULT_LANGUAGE=bam

# Upload limits
NKO_MAX_UPLOAD_BYTES=10485760        # 10 MiB
NKO_MAX_AUDIO_SECONDS=120

# Optional: override lexicon JSON (defaults to the bundled full lexicon)
NKO_LEXICON_PATH=

# Auth
NKO_ACCESS_TOKEN_MINUTES=60

# Comma-separated allowed CORS origins ("" = same-origin only, recommended)
NKO_CORS_ORIGINS=

# development | production
NKO_ENVIRONMENT=development
