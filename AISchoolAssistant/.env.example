# AI School Assistant — local development environment template.
#
# Copy to `.env` and adjust as needed:  cp .env.example .env
# `.env` is git-ignored. NEVER commit real secrets. These defaults are for
# LOCAL DEVELOPMENT ONLY and must never be reused in any shared environment.

# --- Service template ---------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SERVICE_NAME=service-template

# --- Identity / OAuth 2.1 / OIDC ----------------------------------------------
# Secure by default: auth is ON unless explicitly disabled. For local dev
# without Keycloak running, set AUTH_ENABLED=false. When enabled, the three
# OIDC_* values below are REQUIRED (fail-fast validation).
AUTH_ENABLED=false
# OIDC_ISSUER=http://localhost:8080/realms/asa
# OIDC_AUDIENCE=asa-api
# OIDC_JWKS_URI=http://localhost:8080/realms/asa/protocol/openid-connect/certs
# OIDC_CLIENT_ID=asa-api
# Claim carrying the tenant id (default: tenant_id)
# OIDC_TENANT_CLAIM=tenant_id

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=asa
POSTGRES_PASSWORD=asa_dev_password
POSTGRES_DB=asa
KEYCLOAK_DB=keycloak

# --- Keycloak (identity) ------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password

# --- MinIO (S3-compatible object storage) -------------------------------------
MINIO_ROOT_USER=asa
MINIO_ROOT_PASSWORD=asa_dev_password

# --- Endpoints (host -> container) --------------------------------------------
# DATABASE_URL=postgresql://asa:asa_dev_password@localhost:5432/asa
# REDIS_URL=redis://localhost:6379
# QDRANT_URL=http://localhost:6333
# OPENSEARCH_URL=http://localhost:9200
# NATS_URL=nats://localhost:4222
# KEYCLOAK_URL=http://localhost:8080
# TEMPORAL_ADDRESS=localhost:7233
# S3_ENDPOINT=http://localhost:9000

# --- AI providers (never commit real keys) ------------------------------------
# Provider-agnostic: the AI SDK reads these at runtime (see ADR-0002).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
