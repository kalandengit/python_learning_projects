{
  "name": "ai-school-assistant",
  "version": "0.0.0",
  "private": true,
  "description": "Enterprise AI School Assistant platform (SIS, LMS, portals, AI tutors) — Turborepo monorepo.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  }
}
