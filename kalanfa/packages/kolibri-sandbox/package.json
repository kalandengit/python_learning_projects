{
  "name": "kolibri-sandbox",
  "private": true,
  "version": "0.1.0",
  "description": "A library for providing a secure sandbox environment for Kolibri.",
  "main": "src/mainClient.js",
  "scripts": {
    "build-base": "webpack --config ./webpack.config.js",
    "build": "pnpm build-base --mode=production",
    "dev": "pnpm build-base --mode=development --watch",
    "compat": "eslint -c ./compat.js ./src/*.js",
    "build-h5p": "node ./downloadH5PVendor.js && webpack --config ./webpack.config.h5p.js --mode=production"
  },
  "author": "Learning Equality",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-loader": "^10.1.1",
    "css-loader": "7.1.2",
    "css-minimizer-webpack-plugin": "7.0.2",
    "eslint-plugin-compat": "^6.0.2",
    "html-webpack-plugin": "5.6.5",
    "jquery": "3.5.1",
    "jszip": "^3.10.1",
    "mini-css-extract-plugin": "^2.9.4",
    "mutationobserver-shim": "^0.3.7",
    "purgecss": "^6.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.103.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "core-js": "3.47",
    "dayjs": "^1.11.20",
    "iri": "^1.3.1",
    "is-language-code": "^3.1.0",
    "iso8601-duration": "^2.1.3",
    "kolibri-zip": "workspace:*",
    "lodash": "catalog:",
    "toposort-class": "^1.0.1",
    "uuid": "^14.0.1"
  },
  "browserslist": [
    "extends browserslist-config-kolibri"
  ]
}
