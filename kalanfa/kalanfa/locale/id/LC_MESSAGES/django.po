#: core/content/tasks.py:70
msgid "Library updated"
msgstr "Perpustakaan diperbarui"

#. Translators: Message shown to an App user when an update to the library has failed.
#: core/content/tasks.py:73
msgid "Library update failed"
msgstr "Pembaruan perpustakaan gagal"

