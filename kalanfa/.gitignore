*.py[cod]
__pycache__

# Host directory where `make dockerbuild` outputs .pex and .whl files
# same directory is mounted under /docker/mnt inside containers and
# can be used to pass in a pre-build pex file or fixtures for tests
docker/mnt/

# other docker files
docker-whl.cid
docker-whl.iid

# C extensions
*.so

# Packages
.cache
.eggs
*.egg
*.egg-info
dist
dist-packages-temp
dist-packages-cache
build
eggs
parts
bin
var
sdist
develop-eggs
.installed.cfg
lib
lib64
pip

# This can be dynamically changed at build time, and it should never change otherwise
requirements.txt

# Installer logs
pip-log.txt

# Unit test / coverage reports
.coverage*
.tox
nosetests.xml
htmlcov/
kalanfahome_test/

# Translations
kalanfa/locale/**/LC_MESSAGES/*.csv
kalanfa/locale/en/LC_MESSAGES/profiles/*
kalanfa/locale/.crowdin-download-marker
# Same transient Crowdin-upload CSVs, for plugins packaged under python_packages/.
python_packages/*/*/locale/**/LC_MESSAGES/*.csv

# Mr Developer
.mr.developer.cfg
.project
# vscode files
.vscode
# pycharm / jetbrains project files
/*.iml
.pydevproject
.idea/
.junie/
.aiassistant/
.aiignore
.codex*
.qwen/
.vibe/
.aider.config.yml

# Complexity
output/*.html
output/*/index.html

# Sphinx
docs/_build

# node
node_modules
npm-debug.log
yarn-error.log
lerna-debug.log

# Node coverage data
coverage

# webpack built files
kalanfa/**/build/*
kalanfa/**/static/*
js-dist

# Allow static assets to be checked in. For large binary files, use Git LFS
!kalanfa/**/static/assets/
!kalanfa/**/static/assets/*
!kalanfa/**/static/assets/**/*

# swap files
*.swp

# editor files
*.sublime-project
*.sublime-workspace

# Content App
storage/*
kalanfa/content/content_db/*.sqlite3
kalanfa/core/content/contentschema/migrations/*
# Check in h5p & bloom specific files
!kalanfa/core/content/static/h5p/
!kalanfa/core/content/static/bloom/

# virtual environment
venv/
.venv/
.python-version
.envrc
.env
Pipfile

# ignore strange OSX icon files. (Note there are special characters after 'Icon')
# see http://stackoverflow.com/a/30755378
Icon

#ignore added files with DS_Store
.DS_Store

# ignore the VERSION file we use to track the version for whl files
kalanfa/VERSION

# Generated by setuptools-scm
kalanfa/_version.py

# Ignore downloaded crowdin client
build_tools/crowdin-cli.jar

# Ignore pytest cache directory
.pytest_cache/
.pytest_kalanfa_home
.kalanfa_home

# ignore source font files
*.ttf
*.ttc
*.otf

# SQLite file
SQLITE_MAX_VARIABLE_NUMBER.cache

# don't ignore the TTF font for H5P
!h5p-core-18.ttf

# static c extensions cache folder
.cext_cache

# ignore gzipped files
*.gz
# Ignore our special file size cache
*.file_size
