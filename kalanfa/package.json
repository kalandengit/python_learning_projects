{
  "name": "kalanfa-root",
  "version": "0.12.0-dev.1",
  "description": "Development utilities for Kalanfa",
  "scripts": {
    "test": "pnpm run test-jest --watch",
    "test-jest": "jest --config ./jest.conf.js",
    "test-jest-cov": "pnpm run test-jest --coverage",
    "coverage": "pnpm run test-jest-cov",
    "build": "pnpm run sandbox-build && kalanfa-build prod --file ./build_tools/build_plugins.txt --transpile --cache",
    "makemessages": "kalanfa-i18n extract-messages --pluginFile ./build_tools/build_plugins.txt --namespace kalanfa-common --searchPath ./packages/kalanfa-common --namespace kalanfa-core --searchPath ./packages/kalanfa",
    "createprofiles": "kalanfa-i18n profile --pluginFile ./build_tools/build_plugins.txt --output-file ./kalanfa/locale/en/LC_MESSAGES/profiles/strings.csv --namespace kalanfa-common --searchPath ./packages/kalanfa-common --namespace kalanfa-core --searchPath ./packages/kalanfa",
    "auditdittostrings": "kalanfa-i18n audit --pluginFile ./build_tools/build_plugins.txt --output-file ./kalanfa/locale/en/LC_MESSAGES/profiles/ditto.csv --namespace kalanfa-common --searchPath ./packages/kalanfa-common --namespace kalanfa-core --searchPath ./packages/kalanfa",
    "transfercontext": "kalanfa-i18n transfer-context --pluginFile ./build_tools/build_plugins.txt --namespace kalanfa-common --searchPath ./packages/kalanfa-common --namespace kalanfa-core --searchPath ./packages/kalanfa",
    "watch": "kalanfa-build dev --file ./build_tools/build_plugins.txt --cache",
    "watch-hot": "pnpm run watch --hot",
    "python-devserver": "kalanfa start --debug --foreground --port=8000 --settings=kalanfa.deployment.default.settings.dev",
    "python-devserver-no-update": "kalanfa start --debug --skip-update --foreground --port=8000 --settings=kalanfa.deployment.default.settings.dev",
    "frontend-devserver": "concurrently --passthrough-arguments --kill-others \"pnpm run watch --watchonly {1}\" \"pnpm run sandbox-dev\" --",
    "devserver": "concurrently --passthrough-arguments --kill-others \"pnpm run watch --watchonly {1}\" \"pnpm run python-devserver\" \"pnpm run sandbox-dev\" --",
    "devserver-hot": "concurrently --passthrough-arguments --kill-others \"pnpm run watch-hot --watchonly {1}\" \"pnpm run python-devserver\" \"pnpm run sandbox-dev\" --",
    "devserver-with-kds": "concurrently --passthrough-arguments --kill-others \"pnpm run watch --watchonly={2} --require-kds-path --kds-path={1}\" \"pnpm run python-devserver\" \"pnpm run sandbox-dev\" --",
    "bundle-stats": "kalanfa-build prod --file ./build_tools/build_plugins.txt --transpile --json",
    "clean": "rm -fr kalanfa/core/content/static/sandbox/ && kalanfa-build clean --file ./build_tools/build_plugins.txt",
    "lint-frontend": "kalanfa-format --pattern '{kalanfa*/**/frontend,packages,build_tools}/**/*.{js,vue,scss,less,css}' --ignore '**/dist/**' '**/node_modules/**' '**/static/**'",
    "lint-frontend:format": "pnpm run lint-frontend --write",
    "lint-frontend:watch": "pnpm run lint-frontend --monitor",
    "lint-frontend:watch:format": "pnpm run lint-frontend --monitor --write",
    "sandbox-dev": "pnpm --filter kalanfa-sandbox run dev",
    "sandbox-build": "pnpm --filter kalanfa-sandbox run build",
    "compress": "kalanfa-build compress 'kalanfa/*/**/static/**/*.{html,js,css,svg,map,eot,ttf}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/learningequality/kalanfa.git"
  },
  "author": "Learning Equality",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/learningequality/kalanfa/issues"
  },
  "private": true,
  "devDependencies": {
    "@crowdin/cli": "^4.14.1",
    "@types/jest": "^30.0.0",
    "@vueuse/shared": "^11.3.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-jest": "^30.3.0",
    "browserslist-config-kalanfa": "workspace:*",
    "concurrently": "^8.0.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-serializer-vue": "^3.1.0",
    "kalanfa": "workspace:*",
    "kalanfa-build": "workspace:*",
    "kalanfa-common": "workspace:*",
    "kalanfa-format": "workspace:*",
    "kalanfa-glob": "workspace:*",
    "kalanfa-i18n": "workspace:*",
    "kalanfa-logging": "workspace:*",
    "kalanfa-plugin-data": "workspace:*",
    "rewire": "^6.0.0",
    "vue-jest": "^3.0.0",
    "vue-template-compiler": "2.7.16",
    "webpack": "^5.104.0"
  },
  "optionalDependencies": {
    "fsevents": "*"
  },
  "engineStrict": true,
  "engines": {
    "node": "^20.19.0"
  },
  "browserslist": [
    "extends browserslist-config-kalanfa"
  ],
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8",
  "volta": {
    "node": "20.19.3",
    "pnpm": "10.4.1"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js",
      "deasync",
      "es5-ext",
      "node-sass",
      "unrs-resolver",
      "vue-demi"
    ],
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "deasync",
      "es5-ext",
      "node-sass",
      "unrs-resolver",
      "vue-demi"
    ],
    "overrides": {
      "@khanacademy/math-input>mathquill": "github:Khan/mathquill#v1.0.0",
      "vue-jest>vue-template-es2015-compiler": "npm:vue-template-babel-compiler@^2.0.0"
    },
    "packageExtensions": {
      "kolibri-design-system": {
        "dependencies": {
          "browserslist-config-kolibri": "*"
        }
      }
    }
  }
}
