# PROJET_SCHOOL_MOUMA_BKO_2026 - environment variables template
# Copy to .env and fill real values. NEVER commit the real .env file.

# --- Django core ---
# Generate a new key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.dev

# Comma-separated hostnames allowed to serve the app (prod)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (production) ---
# Example: postgres://user:password@db:5432/school_mouma
DATABASE_URL=

# --- Localisation ---
DJANGO_LANGUAGE_CODE=fr
DJANGO_TIME_ZONE=Africa/Bamako

# --- School identity (used on bulletins / documents) ---
ECOLE_NOM=École MOUMA
ECOLE_VILLE=Bamako
ECOLE_ANNEE=2026
ECOLE_DEVISE=XOF
