# EMS backend configuration — copy to .env for local dev. NEVER commit .env.
EMS_ENV=dev
EMS_DATABASE_URL=postgresql+asyncpg://ems:ems@localhost:5432/ems
EMS_VALKEY_URL=redis://localhost:6379/0

# RS256 keypair for JWT (PEM). Generated ephemerally in dev if unset.
# EMS_JWT_PRIVATE_KEY_PEM=
# EMS_JWT_PUBLIC_KEY_PEM=

# 32+ byte random secret for the QR HMAC layer (base64 or raw).
# EMS_QR_HMAC_SECRET=

# ML-DSA-65 keypair (base64). Generated ephemerally in dev if unset.
# EMS_PQC_SECRET_KEY_B64=
# EMS_PQC_PUBLIC_KEY_B64=
# Dev/test only — refused in staging/prod:
EMS_PQC_ALLOW_HMAC_ONLY=true

# AES-256-GCM key (base64, 32 bytes) for TOTP secret encryption at rest.
# EMS_TOTP_ENC_KEY_B64=

# Stripe (test keys only in dev; live keys via AWS Secrets Manager).
# EMS_STRIPE_SECRET_KEY=sk_test_...
# EMS_STRIPE_WEBHOOK_SECRET=whsec_...

EMS_RP_ID=localhost
EMS_RP_ORIGIN=http://localhost:5173
EMS_FRONTEND_BASE_URL=http://localhost:5173

# EMS_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
