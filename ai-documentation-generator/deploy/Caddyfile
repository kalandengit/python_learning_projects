# Reverse proxy for the AI Documentation Generator.
#
# SITE_ADDRESS controls the behaviour with zero rebuilds:
#   :80                      -> plain HTTP on the server IP (test/first boot)
#   docs.example.com         -> automatic HTTPS via Let's Encrypt (needs the
#                               domain's DNS A record pointed at this VPS, and
#                               ports 80+443 reachable)
#
# Set it in deploy/.env, then: docker compose up -d caddy

{$SITE_ADDRESS} {
	encode gzip zstd

	# Preserve large screenshot uploads handled by the app/API routes.
	request_body {
		max_size 25MB
	}

	reverse_proxy web:3000 {
		health_uri /
		health_interval 30s
		health_timeout 10s
	}
}
