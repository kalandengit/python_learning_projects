# ---------------------------------------------------------------------------
# AI Documentation Generator — production environment
# ---------------------------------------------------------------------------
# Copy to deploy/.env on the VPS and fill in real values:
#     cp .env.production.example .env && nano .env
# deploy/.env is git-ignored and is read by docker-compose for BOTH build args
# (NEXT_PUBLIC_*) and container runtime env.
# ---------------------------------------------------------------------------

# --- Public URL of the app -------------------------------------------------
# For a raw-IP test:      http://172.236.240.38
# For a domain + HTTPS:   https://docs.yourdomain.com
NEXT_PUBLIC_APP_URL=http://172.236.240.38

# --- Reverse proxy address (Caddy) -----------------------------------------
# ":80"            -> HTTP on the IP
# "docs.example.com" -> automatic HTTPS (point DNS A record at this VPS first)
SITE_ADDRESS=:80

# --- Supabase (REQUIRED) ---------------------------------------------------
# Create a project at https://supabase.com  ->  Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-secret

# Postgres connection string for running migrations (Project Settings ->
# Database -> Connection string -> URI). Used only by run-migrations.sh.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres

# --- OpenAI (REQUIRED for AI generation) -----------------------------------
OPENAI_API_KEY=sk-your-key
OPENAI_VISION_MODEL=gpt-4.1-mini

# --- Background jobs (Redis runs in-compose; leave as-is) ------------------
REDIS_URL=redis://redis:6379
AI_WORKER_CONCURRENCY=2
AI_JOB_MAX_ATTEMPTS=3

# --- Stripe (billing; test keys are fine to start) -------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly

# --- Analytics (optional) --------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phx_placeholder

# --- Email (optional; Resend) ----------------------------------------------
RESEND_API_KEY=re_placeholder
EMAIL_FROM="DocuPilot AI <onboarding@resend.dev>"

# --- Misc ------------------------------------------------------------------
NOTIFICATION_RETENTION_DAYS=90
NODE_ENV=production
