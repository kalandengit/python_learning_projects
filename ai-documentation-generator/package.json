{
  "name": "ai-documentation-generator",
  "version": "0.13.1",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "worker:ai": "tsx -r tsconfig-paths/register workers/ai-documentation-worker.ts",
    "jobs:drain": "tsx -r tsconfig-paths/register scripts/drain-ai-jobs.ts",
    "db:types": "supabase gen types typescript --local > lib/database.types.ts",
    "postinstall:pdf": "playwright install chromium",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "npm audit --audit-level=high",
    "security:headers": "tsx scripts/check-security-headers.ts",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run security:headers",
    "predeploy": "npm run ci && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "@tiptap/extension-placeholder": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "bullmq": "5.80.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ioredis": "5.10.1",
    "lucide-react": "1.24.0",
    "marked": "18.0.6",
    "nanoid": "5.1.16",
    "next": "15.5.20",
    "openai": "6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "stripe": "22.3.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "playwright": "1.61.1",
    "posthog-js": "1.399.2",
    "posthog-node": "5.40.0",
    "resend": "6.17.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.5",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.19",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "tsconfig-paths": "4.2.0",
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "@testing-library/jest-dom": "6.9.1"
  }
}
