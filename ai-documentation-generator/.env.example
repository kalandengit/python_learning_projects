# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-workers-only

# AI
OPENAI_API_KEY=sk-your-key
OPENAI_VISION_MODEL=gpt-4.1-mini

# Background Jobs
# Use Upstash Redis, Redis Cloud, or local Redis. Leave empty to use DB-only manual drain script.
REDIS_URL=redis://localhost:6379
AI_WORKER_CONCURRENCY=2
AI_JOB_MAX_ATTEMPTS=3

# Stripe - Sprint 07
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly

# Analytics - Sprint 08
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phx_placeholder

# Email - Sprint 10
RESEND_API_KEY=re_placeholder
EMAIL_FROM="DocuPilot AI <onboarding@resend.dev>"

# Notifications
NOTIFICATION_RETENTION_DAYS=90
