# .gitignore for the AI Documentation Generator (Next.js / Node subproject).
#
# The repository root ships a Python-oriented .gitignore that ignores `lib/`
# and `dist/`. Those patterns would wrongly swallow this app's TypeScript
# source (`lib/`) and the committed browser-extension build (`dist/`), so we
# re-include them here, then apply the correct Node/Next ignore rules.

# --- Re-include source wrongly excluded by the root .gitignore ---
!lib/
!browser-extension/dist/

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Next.js / build output ---
.next/
out/
build/
next-env.d.ts

# --- TypeScript incremental build info ---
*.tsbuildinfo

# --- Test / coverage artifacts ---
coverage/
playwright-report/
test-results/
/blob-report/
/playwright/.cache/

# --- Local env files (keep .env.example tracked) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Editor / OS ---
.vercel
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
