# AI School Assistant — environment template.
# Copy to backend/.env for local development. NEVER commit real secrets;
# deployed environments read these from the cloud secrets manager.

ASA_ENVIRONMENT=dev
ASA_LOG_LEVEL=INFO

ASA_DATABASE_URL=postgresql+asyncpg://asa:asa@localhost:5432/asa
ASA_REDIS_URL=redis://localhost:6379/0
ASA_OBJECT_STORE_ENDPOINT=http://localhost:9000

# LLM providers (used from Milestone 2 onward)
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
