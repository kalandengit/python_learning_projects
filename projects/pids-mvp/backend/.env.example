# Copy to .env and adjust. All variables are prefixed PIDS_.

# SQLite (default, zero-infra). For production use PostgreSQL:
# PIDS_DATABASE_URL=postgresql+psycopg://pids:pids@db:5432/pids
PIDS_DATABASE_URL=sqlite:///./pids.db

# CHANGE THIS in production (use a secrets manager, not a file).
PIDS_SECRET_KEY=dev-only-change-me
PIDS_ACCESS_TOKEN_TTL_SECONDS=3600

# Event deduplication window (seconds).
PIDS_DEDUP_WINDOW_SECONDS=30

# Optional distributed dedup/cache.
# PIDS_REDIS_URL=redis://redis:6379/0

# Confidence floor below which detections are ignored.
PIDS_MIN_CONFIDENCE=0.4

PIDS_ENVIRONMENT=development
